# --- Avalanche Fuji ---
FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc
PRIVATE_KEY=0x...                # deployer / principal key (testnet only!)

# EIP-3009 USDC on Fuji (Circle testnet USDC). Faucet: https://faucet.circle.com
USDC=0x5425890298aed601595a70AB815c96711a31Bc65

# ERC-8004 Identity Registry — deploy the reference contracts to Fuji first,
# then paste the address here.
IDENTITY_REGISTRY=0x...

# Deployed MandateRegistry (filled in after `forge script Deploy`)
MANDATE_REGISTRY=0x...

# The agent's signing wallet (holds USDC; the brain never sees this)
AGENT_SIGNER_KEY=0x...
ANTHROPIC_API_KEY=sk-ant-...   # optional: enables the real LLM brain in /app/attack (falls back to scripted without it)
